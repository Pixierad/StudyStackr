# Copy this file to `.env.local` and fill in BOTH values for your own
# Supabase project. `.env.local` is gitignored so your keys never get
# committed.
#
# Get these from:
#   Supabase Dashboard -> Project Settings -> API
#   - "URL"             -> EXPO_PUBLIC_SUPABASE_URL
#   - "anon public key" -> EXPO_PUBLIC_SUPABASE_ANON_KEY
#
# Both are safe to ship in the client bundle: row-level security policies
# (see supabase-setup.sql) make sure each signed-in user only sees their
# own data.

EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=paste-your-anon-public-key-here

# Optional: only set this for a web build that should intentionally bypass
# Supabase accounts and run in local-only mode.
# EXPO_PUBLIC_ALLOW_WEB_LOCAL_MODE=true

# Optional: pin the Metro packager to a specific LAN/Tailscale address so
# physical-device dev builds can reach it. Defaults to 127.0.0.1.
# EXPO_PACKAGER_HOSTNAME=192.168.1.42
